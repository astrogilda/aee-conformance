{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://in-toto.io/attestation/adversarial-execution-evidence/v0.6/schema",
  "title": "Adversarial Execution Evidence v0.6 predicate (NON-NORMATIVE convenience schema)",
  "description": "NON-NORMATIVE convenience schema for the AEE v0.6 predicate. The predicate specification text is authoritative; conflicts are schema bugs. The schema deliberately does not encode the closed basis/method vocabularies or member-presence rules whose violation is VALID-but-fail-closed at the row level (for example an absent method on an artifact-basis row); those are verifier semantics, not shape.",
  "type": "object",
  "required": ["result", "observationEnvironment", "coverage", "attackResults", "issuedAt"],
  "properties": {
    "result": {
      "type": "string",
      "enum": ["pass", "degraded", "fail"],
      "description": "Recomputable: a consumer MUST be able to recompute this from the rest of the predicate."
    },
    "observationEnvironment": {
      "type": "object",
      "required": ["substrate", "corpus", "catchPolicy", "networkPosture", "observationVocabulary"],
      "properties": {
        "substrate": { "$ref": "#/$defs/digestRef" },
        "corpus": {
          "type": "object",
          "required": ["digest", "manifest"],
          "properties": {
            "name": { "type": "string" },
            "uri": { "type": "string" },
            "digest": { "$ref": "#/$defs/digestSet" },
            "manifest": {
              "type": "object",
              "required": ["classes"],
              "properties": {
                "classes": {
                  "type": "object",
                  "additionalProperties": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "catchPolicy": {
          "type": "object",
          "required": ["digest"],
          "properties": { "digest": { "$ref": "#/$defs/digestSet" } }
        },
        "networkPosture": {
          "type": "object",
          "required": ["posture", "digest"],
          "properties": {
            "posture": { "type": "string" },
            "digest": { "$ref": "#/$defs/digestSet" }
          }
        },
        "observationVocabulary": {
          "type": "object",
          "required": ["digest", "labels", "caught"],
          "properties": {
            "digest": { "$ref": "#/$defs/digestSet" },
            "labels": { "type": "array", "items": { "type": "string" } },
            "caught": { "type": "array", "items": { "type": "string" } }
          }
        },
        "runEntropy": {
          "type": "object",
          "required": ["digest"],
          "properties": { "digest": { "$ref": "#/$defs/digestSet" } }
        }
      }
    },
    "coverage": {
      "type": "object",
      "required": ["assessedClasses", "outOfScope", "routedElsewhere"],
      "properties": {
        "assessedClasses": { "type": "array", "items": { "type": "string" } },
        "outOfScope": { "type": "object", "additionalProperties": { "type": "string" } },
        "routedElsewhere": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "attackResults": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["attackId", "containmentObserved", "actualLayer"],
        "properties": {
          "attackId": { "type": "string" },
          "containmentObserved": { "type": "string" },
          "basis": { "type": "string" },
          "method": { "type": "string" },
          "actualLayer": { "type": "string" },
          "observationRefs": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
          "observationSelectors": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "observationRecords": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["payload", "payloadType", "signatures"],
        "properties": {
          "payload": { "type": "string" },
          "payloadType": { "type": "string" },
          "signatures": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["sig"],
              "properties": {
                "keyid": { "type": "string" },
                "sig": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "batchRoot": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "doesNotAssert": { "type": "array", "items": { "type": "string" } },
    "issuedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "digestSet": {
      "type": "object",
      "properties": { "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" } }
    },
    "digestRef": {
      "type": "object",
      "required": ["digest"],
      "properties": {
        "name": { "type": "string" },
        "digest": { "$ref": "#/$defs/digestSet" }
      }
    }
  }
}
